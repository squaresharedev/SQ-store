# ---------------------------------------------------------------------------
# Square Share — dashboard.squareshare.eu (creator dashboard)
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored; NEVER commit real keys.
# ---------------------------------------------------------------------------

# Shared Supabase project ("Homepage", ref: fdpviaqzbxowvonuoktc).
# Safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL="https://fdpviaqzbxowvonuoktc.supabase.co"

# Publishable / anon key (public, safe in the browser). Use the modern
# publishable key (sb_publishable_...) or the legacy anon JWT — either works.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"

# Public origin of this app. Used as the fallback absolute URL for building
# email redirect links when no request host header is available. In prod,
# set to "https://dashboard.squareshare.eu".
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: override the auth-cookie domain. Leave unset to use the default
# (".squareshare.eu" in production, host-only in local dev).
# NEXT_PUBLIC_COOKIE_DOMAIN=".squareshare.eu"

# ---------------------------------------------------------------------------
# Stripe (payments/payouts). Get keys from the Stripe dashboard.
# The publishable key is safe in the browser; the secret and webhook signing
# keys are server-only and must never be prefixed with NEXT_PUBLIC_.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="paste-stripe-publishable-key-here"
# STRIPE_SECRET_KEY="paste-stripe-secret-key-here"
# STRIPE_WEBHOOK_SECRET="paste-stripe-webhook-signing-secret-here"

# ---------------------------------------------------------------------------
# SERVER-ONLY SECRETS — never prefix with NEXT_PUBLIC_ and never commit.
# ---------------------------------------------------------------------------
# Service role key (Supabase → Project Settings → API). Bypasses RLS. Required
# by the dev seed/reset scripts (scripts/seed.ts, scripts/reset-seed.ts) and any
# future server-side privileged calls. Server-side ONLY — never bundled.
# SUPABASE_SERVICE_ROLE_KEY="paste-service-role-secret-here"

# ---------------------------------------------------------------------------
# DEV SEEDING (scripts/seed.ts + scripts/reset-seed.ts) — never set in prod.
# The scripts fail closed: they refuse to run unless SEED_ENV is exactly "dev".
# ---------------------------------------------------------------------------
# Opt-in flag. Set to "dev" ONLY on a disposable dev target you may seed/wipe.
# SEED_ENV="dev"

# Auth user id whose data the scripts create/delete. MUST be the account you
# sign in to /dashboard with (Supabase → Auth → Users → your user's UID),
# otherwise the dashboard (which shows the session user's rows) looks empty.
# TEST_SELLER_ID="00000000-0000-0000-0000-000000000000"

# Optional belt-and-suspenders: comma-separated Supabase project ref(s) the
# scripts are allowed to touch. If set, a mismatching project ref aborts the run.
# SEED_ALLOWED_PROJECT_REF="your-dev-project-ref"

# Cloudflare R2 (product uploads). Create an R2 API token in the Cloudflare
# dashboard (R2 > Manage API Tokens > Object Read & Write, scoped to the
# squareshare-products bucket). Account ID is on the dashboard sidebar.
R2_ACCOUNT_ID="32f68a5e041d51b08934ca72a42a2922"
R2_ACCESS_KEY_ID="paste-r2-access-key-id-here"
R2_SECRET_ACCESS_KEY="paste-r2-secret-access-key-here"
R2_BUCKET_NAME="squareshare-products"
