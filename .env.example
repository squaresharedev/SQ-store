# ---------------------------------------------------------------------------
# Square Share — store.squareshare.to (creator dashboard)
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored; NEVER commit real keys.
# ---------------------------------------------------------------------------

# Shared Supabase project ("Homepage", ref: fdpviaqzbxowvonuoktc).
# Safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL="https://fdpviaqzbxowvonuoktc.supabase.co"

# Publishable / anon key (public, safe in the browser). Use the modern
# publishable key (sb_publishable_...) or the legacy anon JWT — either works.
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"

# Optional: override the auth-cookie domain. Leave unset to use the default
# (".squareshare.to" in production, host-only in local dev).
# NEXT_PUBLIC_COOKIE_DOMAIN=".squareshare.to"

# ---------------------------------------------------------------------------
# SERVER-ONLY SECRETS — never prefix with NEXT_PUBLIC_ and never commit.
# Not needed yet for the auth screen; add when server-side privileged calls
# (admin/service operations) are implemented.
# ---------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY="paste-service-role-secret-here"

# Cloudflare R2 (product uploads). Create an R2 API token in the Cloudflare
# dashboard (R2 > Manage API Tokens > Object Read & Write, scoped to the
# squareshare-products bucket). Account ID is on the dashboard sidebar.
R2_ACCOUNT_ID="32f68a5e041d51b08934ca72a42a2922"
R2_ACCESS_KEY_ID="paste-r2-access-key-id-here"
R2_SECRET_ACCESS_KEY="paste-r2-secret-access-key-here"
R2_BUCKET_NAME="squareshare-products"
